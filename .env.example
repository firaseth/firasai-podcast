# ── FirasAi Agent — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your keys. Never commit .env to Git.

# AI
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...

# Voice
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=voice_id_here

# Content & Distribution
NOTION_API_KEY=secret_...
BUZZSPROUT_API_KEY=...
BUZZSPROUT_PODCAST_ID=...
BUFFER_ACCESS_TOKEN=...
BEEHIIV_API_KEY=...
BEEHIIV_PUBLICATION_ID=...

# Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# Notion Database IDs (find these in the URL of each Notion database)
NOTION_EPISODES_DB=database_id_here
NOTION_GUESTS_DB=database_id_here
NOTION_CALENDAR_DB=database_id_here
NOTION_CLIPS_DB=database_id_here
